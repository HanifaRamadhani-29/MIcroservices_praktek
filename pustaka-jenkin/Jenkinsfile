pipeline {
    agent any

    stages {
        stage('Ambil Kode') {
            steps {
                // Pastikan URL repo kamu benar
                git branch: 'main', url: 'https://github.com/HanifaRamadhani-29/MIcroservices_praktek'
            }
        }

        stage('Build & Run Microservices') {
            steps {
                echo 'Membersihkan container lama dan menjalankan yang baru...'
                dir('pustaka-jenkin') {
                    // Berhenti dulu baru jalanin lagi (agar bersih)
                    sh 'docker-compose down'
                    sh 'docker-compose up -d --build'
                }
            }
        }

        stage('Verifikasi') {
            steps {
                echo 'Cek container yang sedang jalan:'
                sh 'docker ps'
            }
        }
    }
}